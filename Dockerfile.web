FROM node:22-slim AS build

WORKDIR /app

ARG VITE_API_BASE_URL
ARG VITE_ADK_VOICE_BASE_URL

COPY package.json package-lock.json tsconfig.base.json ./
COPY apps/web/package.json apps/web/package.json
COPY packages/contracts/package.json packages/contracts/package.json

RUN npm ci --workspace @voice-agent/web --workspace @voice-agent/contracts

COPY apps/web apps/web
COPY packages/contracts packages/contracts

RUN test -n "$VITE_API_BASE_URL" || (echo "VITE_API_BASE_URL build arg is required" >&2; exit 1); \
    test -n "$VITE_ADK_VOICE_BASE_URL" || (echo "VITE_ADK_VOICE_BASE_URL build arg is required" >&2; exit 1); \
    VITE_API_BASE_URL="$VITE_API_BASE_URL" \
    VITE_ADK_VOICE_BASE_URL="$VITE_ADK_VOICE_BASE_URL" \
    npm run build -w @voice-agent/web

FROM nginx:1.27-alpine AS runtime

ENV PORT=8080

COPY apps/web/nginx.conf /etc/nginx/templates/default.conf.template
COPY --from=build /app/apps/web/dist /usr/share/nginx/html

EXPOSE 8080
